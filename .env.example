# ────────────────────────────────────────────────────────────────
# Bungalooo — примерен конфигурационен файл (БЕЗ тайни ключове)
#
# 1. Копирайте този файл като „.env.local“ в същата папка.
# 2. Попълнете стойностите от вашия Firebase проект:
#    Firebase конзола → ⚙ Project settings → General →
#    „Your apps“ → изберете уеб приложението → SDK setup → Config.
#
# ЗАБЕЛЕЖКА: Тези стойности на Firebase НЕ са тайни пароли — те са
# публични идентификатори на проекта и е нормално да са в кода на
# приложението. Реалната защита идва от правилата на Firestore и от
# входа с парола. Затова файлът .env.local не се качва в Git само за
# по-голяма чистота, а не защото стойностите са опасни.
# ────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Имейлът на единствения „редакторски" акаунт, чиято ПАРОЛА е общата
# парола за редактиране. Този имейл НЕ е таен. Създава се веднъж в
# Firebase конзолата (Authentication → Users → Add user).
VITE_EDITOR_EMAIL=editor@bungalooo.app
