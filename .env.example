# ────────────────────────────────────────────────────────────────
# Bungalooo — примерен конфигурационен файл (БЕЗ тайни ключове)
#
# 1. Копирайте този файл като „.env.local" в същата папка.
# 2. Попълнете двете стойности от вашия Supabase проект:
#    Supabase конзола → вашия проект → Settings → API
#      • Project URL          → VITE_SUPABASE_URL
#      • Project API keys → „anon public"  → VITE_SUPABASE_ANON_KEY
#
# За да заработи синхронизацията и на живия сайт (GitHub Pages),
# същите две стойности се записват и във файла „.env.production"
# (те са публични идентификатори, не тайни пароли — сигурността идва
# от правилата RLS в базата и от входа с парола).
# ────────────────────────────────────────────────────────────────

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Имейл на единствения „редакторски" акаунт, чиято ПАРОЛА е общата
# парола за редактиране. Този имейл НЕ е таен. Създава се веднъж в
# Supabase (Authentication → Users → Add user, с отметка Auto Confirm).
VITE_EDITOR_EMAIL=editor@bungalooo.app
